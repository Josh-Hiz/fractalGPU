{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 18,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_CXX_STANDARD": "20",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "cpu-debug",
            "displayName": "CPU Debug",
            "description": "CPU renderer, debug symbols, no optimisation",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "FRACTAL_ENABLE_CUDA": "OFF"
            }
        },
        {
            "name": "cpu-release",
            "displayName": "CPU Release",
            "description": "CPU renderer, fully optimised",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "FRACTAL_ENABLE_CUDA": "OFF"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "cpu-debug",
            "configurePreset": "cpu-debug"
        },
        {
            "name": "cpu-release",
            "configurePreset": "cpu-release"
        }
    ]
}