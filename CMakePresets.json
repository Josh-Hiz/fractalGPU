{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 18,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_CXX_STANDARD": "20",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "cpu-debug",
            "displayName": "CPU Debug",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "FRACTAL_ENABLE_CUDA": "OFF"
            }
        },
        {
            "name": "cpu-release",
            "displayName": "CPU Release",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "FRACTAL_ENABLE_CUDA": "OFF"
            }
        },
        {
            "name": "gpu-debug",
            "displayName": "GPU Debug (CUDA)",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "FRACTAL_ENABLE_CUDA": "ON",
                "CMAKE_CUDA_COMPILER": "/usr/local/cuda-13/bin/nvcc",
                "CUDAToolkit_ROOT": "/usr/local/cuda-13"
            }
        },
        {
            "name": "gpu-release",
            "displayName": "GPU Release (CUDA)",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "FRACTAL_ENABLE_CUDA": "ON",
                "CMAKE_CUDA_COMPILER": "/usr/local/cuda-13/bin/nvcc",
                "CUDAToolkit_ROOT": "/usr/local/cuda-13"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "cpu-debug",
            "configurePreset": "cpu-debug"
        },
        {
            "name": "cpu-release",
            "configurePreset": "cpu-release"
        },
        {
            "name": "gpu-debug",
            "configurePreset": "gpu-debug"
        },
        {
            "name": "gpu-release",
            "configurePreset": "gpu-release"
        }
    ]
}
